# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=manava
POSTGRES_USER=manava
POSTGRES_PASSWORD=manava_dev_change_me
POSTGRES_PORT=5432

# ── Backend (manava-api) ─────────────────────────────────────────────────────
API_PORT=4000
DATABASE_URL=postgresql://manava:manava_dev_change_me@postgres:5432/manava?schema=public
JWT_ACCESS_SECRET=change_this_to_a_random_string_at_least_24_chars
JWT_REFRESH_SECRET=change_this_to_a_different_random_string_min_24_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=10
NODE_ENV=development

# ── Frontend (manava-app) ────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
