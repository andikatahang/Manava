import React, { useState, useMemo, type ReactNode, type CSSProperties } from "react";
import {
  LineChart, Line, AreaChart, Area, XAxis, YAxis, Tooltip,
  ResponsiveContainer, CartesianGrid, ReferenceLine
} from "recharts";
import {
  TrendingUp, TrendingDown, Minus, Sparkles, AlertTriangle,
  CheckCircle2, ChevronDown, Scan, type LucideIcon
} from "lucide-react";

// ---- Design tokens -----------------------------------------------------
// Palette lifted from color-grading scopes: near-black stage, teal/orange
// complementary pair (the classic film LUT split-tone), warm parchment text.
const C = {
  bg: "#0B0F12",
  panel: "#12171B",
  panelRaised: "#171D22",
  line: "#232B31",
  teal: "#3FC1C9",
  tealDim: "#1F5A5E",
  amber: "#E8873A",
  amberDim: "#6B4423",
  text: "#E7EEF0",
  textMuted: "#7C8A92",
  textFaint: "#4B565C",
  danger: "#E0654F",
} as const;

const MONTHS = ["Feb", "Mar", "Apr", "Mei", "Jun", "Jul"] as const;

interface TrendPoint {
  month: string;
  score: number;
}

interface MemberSeed {
  name: string;
  role: string;
  seed: number;
  base: number;
  drift: number;
}

interface Member extends MemberSeed {
  trend: TrendPoint[];
}

type InsightTone = "warn" | "good" | "neutral";

interface Insight {
  tone: InsightTone;
  title: string;
  body: string;
}

function genTrend(base: number, drift: number, seed: number): TrendPoint[] {
  let v = base;
  return MONTHS.map((m, i) => {
    v += drift + Math.sin(seed + i * 1.7) * 3.5;
    v = Math.max(55, Math.min(98, v));
    return { month: m, score: Math.round(v * 10) / 10 };
  });
}

const DEPT_TREND: TrendPoint[] = genTrend(78, 0.6, 0.4);

const MEMBER_SEEDS: MemberSeed[] = [
  { name: "M. Andika Tahang", role: "Senior Retoucher", seed: 1.1, base: 82, drift: -1.8 },
  { name: "M. Hafizh Hakim", role: "Color Grader", seed: 2.4, base: 76, drift: 1.4 },
  { name: "Prima Uziel N.", role: "Video Editor", seed: 3.9, base: 88, drift: 0.4 },
  { name: "Mohammad Nabil", role: "Retoucher", seed: 0.6, base: 71, drift: 2.1 },
  { name: "Dinda Ayu P.", role: "Color Grader", seed: 4.7, base: 79, drift: -0.3 },
  { name: "Rizky Fadillah", role: "Video Editor", seed: 1.8, base: 84, drift: 0.9 },
];

const MEMBERS: Member[] = MEMBER_SEEDS.map((m) => ({
  ...m,
  trend: genTrend(m.base, m.drift, m.seed),
}));

function currentScore(trend: TrendPoint[]): number {
  return trend[trend.length - 1].score;
}

function delta(trend: TrendPoint[]): number {
  return Math.round((trend[trend.length - 1].score - trend[0].score) * 10) / 10;
}

function TrendBadge({ d }: { d: number }) {
  const up = d > 1;
  const down = d < -1;
  const Icon = up ? TrendingUp : down ? TrendingDown : Minus;
  const color = up ? C.teal : down ? C.danger : C.textMuted;
  return (
    <span style={{ color, display: "inline-flex", alignItems: "center", gap: 4, fontFamily: "'JetBrains Mono', monospace", fontSize: 12 }}>
      <Icon size={13} strokeWidth={2.5} />
      {d > 0 ? "+" : ""}
      {d}
    </span>
  );
}

function ScopeFrame({ children, corner = 8 }: { children: ReactNode; corner?: number }) {
  // Signature element: viewfinder-style corner brackets, echoing a
  // color-grading monitor / camera scope readout.
  const s: CSSProperties = { position: "absolute", width: 12, height: 12, borderColor: C.textFaint };
  return (
    <div style={{ position: "relative" }}>
      <div style={{ ...s, top: corner, left: corner, borderTop: "1.5px solid", borderLeft: "1.5px solid" }} />
      <div style={{ ...s, top: corner, right: corner, borderTop: "1.5px solid", borderRight: "1.5px solid" }} />
      <div style={{ ...s, bottom: corner, left: corner, borderBottom: "1.5px solid", borderLeft: "1.5px solid" }} />
      <div style={{ ...s, bottom: corner, right: corner, borderBottom: "1.5px solid", borderRight: "1.5px solid" }} />
      {children}
    </div>
  );
}

function DeptChart() {
  return (
    <ResponsiveContainer width="100%" height={220}>
      <AreaChart data={DEPT_TREND} margin={{ top: 10, right: 18, left: -12, bottom: 0 }}>
        <defs>
          <linearGradient id="deptFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={C.teal} stopOpacity={0.35} />
            <stop offset="100%" stopColor={C.teal} stopOpacity={0} />
          </linearGradient>
        </defs>
        <CartesianGrid stroke={C.line} strokeDasharray="2 6" vertical={false} />
        <XAxis dataKey="month" stroke={C.textFaint} tick={{ fill: C.textMuted, fontSize: 11, fontFamily: "JetBrains Mono" }} axisLine={{ stroke: C.line }} tickLine={false} />
        <YAxis domain={[50, 100]} stroke={C.textFaint} tick={{ fill: C.textMuted, fontSize: 11, fontFamily: "JetBrains Mono" }} axisLine={false} tickLine={false} width={28} />
        <ReferenceLine y={80} stroke={C.amberDim} strokeDasharray="3 3" />
        <Tooltip
          contentStyle={{ background: C.panelRaised, border: `1px solid ${C.line}`, borderRadius: 6, fontFamily: "JetBrains Mono", fontSize: 12 }}
          labelStyle={{ color: C.textMuted }}
          itemStyle={{ color: C.teal }}
        />
        <Area type="monotone" dataKey="score" stroke={C.teal} strokeWidth={2} fill="url(#deptFill)" dot={{ r: 2, fill: C.teal, strokeWidth: 0 }} activeDot={{ r: 4 }} />
      </AreaChart>
    </ResponsiveContainer>
  );
}

function MemberCard({ m }: { m: Member }) {
  const d = delta(m.trend);
  const score = currentScore(m.trend);
  const color = d < -1 ? C.danger : C.teal;
  return (
    <div style={{ background: C.panelRaised, border: `1px solid ${C.line}`, borderRadius: 10, padding: "14px 16px" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
        <div>
          <div style={{ color: C.text, fontSize: 13.5, fontWeight: 600, letterSpacing: 0.1 }}>{m.name}</div>
          <div style={{ color: C.textMuted, fontSize: 11.5, marginTop: 2 }}>{m.role}</div>
        </div>
        <div style={{ textAlign: "right" }}>
          <div style={{ fontFamily: "'JetBrains Mono', monospace", color: C.text, fontSize: 20, fontWeight: 600, lineHeight: 1 }}>{score}</div>
          <div style={{ marginTop: 4 }}>
            <TrendBadge d={d} />
          </div>
        </div>
      </div>
      <div style={{ height: 46, marginTop: 8, marginLeft: -6 }}>
        <ResponsiveContainer width="100%" height="100%">
          <LineChart data={m.trend} margin={{ top: 4, right: 4, left: 0, bottom: 0 }}>
            <Line type="monotone" dataKey="score" stroke={color} strokeWidth={1.8} dot={false} />
          </LineChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

