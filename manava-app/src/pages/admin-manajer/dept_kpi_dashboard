function InsightCard({ tone, title, body }: Insight) {
  const { Icon, color } = INSIGHT_STYLE[tone];
  return (
    <div style={{ display: "flex", gap: 12, padding: "14px 4px", borderBottom: `1px solid ${C.line}` }}>
      <div style={{ flexShrink: 0, width: 30, height: 30, borderRadius: 7, background: `${color}1A`, display: "flex", alignItems: "center", justifyContent: "center", marginTop: 1 }}>
