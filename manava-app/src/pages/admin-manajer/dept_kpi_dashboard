              </span>
              {s.d !== null && <TrendBadge d={s.d} />}
            </div>
          </div>
        ))}
      </div>

      {/* Dept trend chart */}
      <ScopeFrame>
        <div style={{ background: C.panel, border: `1px solid ${C.line}`, borderRadius: 12, padding: "18px 18px 6px", marginBottom: 18 }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 4 }}>
