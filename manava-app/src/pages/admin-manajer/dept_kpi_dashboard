const INSIGHT_STYLE: Record<InsightTone, { Icon: LucideIcon; color: string }> = {
  warn: { Icon: AlertTriangle, color: C.amber },
  good: { Icon: CheckCircle2, color: C.teal },
  neutral: { Icon: Sparkles, color: C.textMuted },
