              Admin Manajer &middot; Dept. Color &amp; Retouch
            </div>
            <div style={{ fontSize: 19, fontWeight: 700 }}>Ringkasan Kinerja Tim</div>
          </div>
        </div>
        <button
          style={{
            display: "flex",
            alignItems: "center",
            gap: 8,
            background: C.panel,
            border: `1px solid ${C.line}`,
            color: C.textMuted,
            borderRadius: 8,
            padding: "8px 12px",
